{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing/index.html"
    },
    {
      "source": "/style.css",
      "destination": "/landing/style.css"
    },
    {
      "source": "/script.js",
      "destination": "/landing/script.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    }
  ]
}
